# Postgres
POSTGRES_USER=openlog
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=openlog

# App
JWT_SECRET=change-me-very-long-random-string-at-least-32-chars
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://openlog.in/auth/callback

# Storage (MinIO)
STORAGE_ACCESS_KEY=change-me-minio-user
STORAGE_SECRET_KEY=change-me-minio-password
STORAGE_BUCKET=openlog
STORAGE_REGION=us-east-1

# Frontend
NEXT_PUBLIC_API_URL=https://api.openlog.in

# Docker Hub
DOCKER_USERNAME=your-dockerhub-username
