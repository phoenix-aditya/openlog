# Postgres
POSTGRES_USER=openlog
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=openlog

# App
JWT_SECRET=change-me-very-long-random-string-at-least-32-chars

# Storage (MinIO — running in Docker alongside the app)
STORAGE_ACCESS_KEY=change-me-minio-access-key
STORAGE_SECRET_KEY=change-me-minio-secret-key

# Docker Hub (used by docker-compose.prod.yml to pull images)
DOCKER_USERNAME=your-dockerhub-username
